# =============================================================================
# yolo-train environment variables (copy to .env and adjust)
# =============================================================================

# --- General -----------------------------------------------------------------
PYTHONUNBUFFERED=1

# --- PDF rendering -----------------------------------------------------------
# DPI for PDF -> PNG rasterization
PDF_RENDER_DPI=300
# Maximum long edge for normalized scans (px)
SCAN_MAX_LONG_EDGE=4096

# --- CVAT (local docker-compose) --------------------------------------------
# Hostname/ports CVAT will be exposed at on the host machine
CVAT_HOST=localhost
CVAT_PORT=8080

# Superuser bootstrap (used by `make cvat-create-superuser`)
CVAT_SUPERUSER_USERNAME=admin
CVAT_SUPERUSER_EMAIL=admin@example.com
CVAT_SUPERUSER_PASSWORD=changeme

# Absolute path on host that will be mounted into CVAT as /home/django/share
# Defaults to <project_root>/data/cvat_shared
CVAT_SHARE_PATH=

# CVAT REST API (optional, for scripts/create_cvat_tasks.py and
# scripts/export_cvat_annotations.py)
CVAT_API_URL=http://localhost:8080/api
CVAT_API_USER=admin
CVAT_API_PASSWORD=changeme

# --- Project name conventions ------------------------------------------------
CVAT_PROJECT_PAGE_CLS=D2DXF_PAGE_CLASSIFICATION
CVAT_PROJECT_DRAWING_SEG=D2DXF_DRAWING_SEGMENTATION

# --- Training ----------------------------------------------------------------
# CUDA device id(s), e.g. "0" or "0,1" or "" for CPU
CUDA_VISIBLE_DEVICES=0
ULTRALYTICS_OFFLINE=0

# --- Production target -------------------------------------------------------
# Path to drawing2dxf project (used by `make install-models-to-project`)
DRAWING2DXF_PROJECT=../drawing2dxf
